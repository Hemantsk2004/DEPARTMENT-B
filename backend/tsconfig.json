{
  "compilerOptions": {
    "target": "ES2020",

    "module": "Node16",
    "moduleResolution": "Node16",

    "rootDir": "./src",
    "outDir": "./dist",

    "esModuleInterop": true,
    "sourceMap": true,

    "strict": false,
    "skipLibCheck": true,

    "typeRoots": [
      "./src/@types",
      "./node_modules/@types"
    ],

    "lib": ["ES2020"]
  },

  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist"
  ]
}